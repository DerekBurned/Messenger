@startuml SEQ01_SendMessage_EN
!theme plain
skinparam sequenceArrowThickness 2
skinparam sequenceParticipant underline

title Sequence Diagram: Send Text Message

actor "User" as user
participant "ChatScreen\n(Compose UI)" as ui
participant "ChatViewModel" as vm
participant "SendMessageUseCase" as uc
participant "GetCurrentUserUseCase" as gcu
participant "IAuthRepository" as auth
participant "MessageRepositoryImpl" as repo
participant "MessageDao\n(Room)" as dao
participant "FirestoreService" as firestore

autonumber

user -> ui : Types message text\nand taps Send button
activate ui

ui -> vm : sendMessage(text)
activate vm

vm -> vm : _uiState.update { copy(isSending = true) }

vm -> uc : invoke(conversationId, text)
activate uc

note over uc : Flow<Resource<Unit>> emission begins

' === Validation ===
alt text.isBlank()
    uc --> vm : emit Resource.Error("Message is empty")
    vm -> vm : _uiState.update { copy(isSending = false, error = msg) }
    vm --> ui : StateFlow<ChatUiState> recompose
    ui --> user : Show error
else text.length > 5000
    uc --> vm : emit Resource.Error("Message is too long")
    vm -> vm : _uiState.update { copy(isSending = false, error = msg) }
    vm --> ui : StateFlow<ChatUiState> recompose
    ui --> user : Show error
else Valid text
    ' === Get current user ===
    uc -> gcu : invoke()
    activate gcu
    gcu -> auth : getCurrentUser()
    activate auth
    auth --> gcu : User?
    deactivate auth
    gcu --> uc : User?
    deactivate gcu

    alt currentUser == null
        uc --> vm : emit Resource.Error("User not logged in")
        vm -> vm : _uiState.update { copy(isSending = false, error = msg) }
        vm --> ui : StateFlow<ChatUiState> recompose
        ui --> user : Show error
    else User authenticated
        ' === Create message ===
        uc -> uc : Create Message(\n  id = UUID.randomUUID(),\n  conversationId,\n  senderId = currentUser.id,\n  text = text.trim(),\n  timestamp = currentTimeMillis(),\n  status = SENDING\n)

        ' === Send via repository ===
        uc -> repo : sendMessage(message)
        activate repo

        note right of repo : Optimistic local save\nwith SENDING status

        repo -> dao : insertMessage(message.toEntity())
        activate dao
        dao --> repo : Unit
        deactivate dao

        repo -> firestore : sendMessage(message)
        activate firestore

        alt Firestore success
            firestore --> repo : Result.success(Unit)
            deactivate firestore

            repo -> dao : updateMessageStatus(message.id, SENT)
            activate dao
            dao --> repo : Unit
            deactivate dao

            repo --> uc : Result.success(Unit)
            deactivate repo

            uc --> vm : emit Resource.Success(Unit)

            vm -> vm : _uiState.update {\n  copy(isSending = false, error = null)\n}

            vm --> ui : StateFlow<ChatUiState> recompose
            ui --> user : Message appears in\nchat list with SENT status

        else Firestore failure
            firestore --> repo : Result.failure(exception)

            repo --> uc : Result.failure(exception)
            deactivate repo

            uc --> vm : emit Resource.Error("Failed to send message")

            vm -> vm : _uiState.update {\n  copy(isSending = false, error = msg)\n}

            vm --> ui : StateFlow<ChatUiState> recompose
            ui --> user : Message shows FAILED status\nor error toast
        end
    end
end

deactivate uc
deactivate vm
deactivate ui

@enduml
