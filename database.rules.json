{
  "rules": {
    "presence": {
      "$userId": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $userId",
        ".validate": "newData.hasChildren(['state', 'lastSeen'])",
        "state": {
          ".validate": "newData.isString() && (newData.val() === 'online' || newData.val() === 'away' || newData.val() === 'offline')"
        },
        "lastSeen": {
          ".validate": "newData.isNumber()"
        },
        "lastChanged": {
          ".validate": "newData.val() === now"
        }
      }
    },
    "typing": {
      "$conversationId": {
        "$userId": {
          ".read": "auth != null",
          ".write": "auth != null && auth.uid === $userId",
          ".validate": "newData.hasChild('timestamp') || !newData.exists()",
          "timestamp": {
            ".validate": "newData.val() === now"
          }
        }
      }
    },
    "receipts": {
      "$conversationId": {
        "$userId": {
          ".read": "auth != null",
          ".write": "auth != null && auth.uid === $userId",
          "lastDeliveredTimestamp": {
            ".validate": "newData.isNumber()"
          },
          "lastReadTimestamp": {
            ".validate": "newData.isNumber()"
          }
        }
      }
    },
    "calls": {
      "$callId": {
        ".read": "auth != null && data.exists() && (data.child('callerId').val() === auth.uid || data.child('calleeId').val() === auth.uid)",
        ".write": "auth != null && ((newData.exists() && (newData.child('callerId').val() === auth.uid || newData.child('calleeId').val() === auth.uid)) || (data.exists() && (data.child('callerId').val() === auth.uid || data.child('calleeId').val() === auth.uid)))",
        "callerId":   { ".validate": "newData.isString()" },
        "calleeId":   { ".validate": "newData.isString()" },
        "channelName": { ".validate": "newData.isString()" },
        "status":     { ".validate": "newData.isString()" }
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
